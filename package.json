{
  "name": "custom-3d-prints",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run build:css && vite --host 0.0.0.0",
    "build": "npm run build:css",
    "build:css": "tailwindcss -i ./src/styles.css -o ./assets/styles.css --minify",
    "watch:css": "tailwindcss -i ./src/styles.css -o ./assets/styles.css --watch"
  },
  "devDependencies": {
    "@tailwindcss/cli": "4.2.4",
    "@tailwindcss/typography": "0.5.19",
    "tailwindcss": "4.2.4",
    "vite": "8.0.10"
  }
}
